# E-commerce template environment example
# Copiar este archivo como .env para trabajar local.
# En Render cargar las mismas variables en Environment.
# No subir nunca el archivo .env real a GitHub.

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
STORE_NAME=AyRe
SERVICE_NAME=ayre-api
APP_SECRET=cambia_esto_por_una_clave_larga_aleatoria
ADMIN_EMAIL=admin@tu-dominio.com
ADMIN_PASSWORD=cambia_esto_por_una_contrasena_larga
# Opcional: solo para integraciones servidor-a-servidor, no usar en el frontend.
ADMIN_API_KEY=

# Frontend / API
# Local:
CLIENT_ORIGIN=http://127.0.0.1:5173
VITE_API_URL=http://127.0.0.1:3001/api
PUBLIC_APP_URL=http://127.0.0.1:3001

# Render:
# CLIENT_ORIGIN=https://tu-tienda.onrender.com
# VITE_API_URL=/api
# PUBLIC_APP_URL=https://tu-tienda.onrender.com

# WhatsApp en formato internacional, sin + ni espacios.
VITE_WHATSAPP_NUMBER=5490000000000
# WhatsApp interno para avisos de nuevos pedidos al admin.
ADMIN_WHATSAPP_NUMBER=5490000000000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@TU_CLUSTER.mongodb.net/tu-tienda?retryWrites=true&w=majority
MONGODB_DB_NAME=tu-tienda

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_FOLDER=tu-tienda-products

# Email transaccional con Resend
# Para probar rapido se puede usar onboarding@resend.dev.
# Para produccion conviene verificar un dominio propio en Resend.
RESEND_API_KEY=re_tu_api_key
RESEND_FROM=AyRe <onboarding@resend.dev>
